generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Site {
  id             String   @id @default(cuid())
  name           String
  sitePrompt     String   @default("")
  domain         String?
  locked         Boolean  @default(false)
  memorySummary  String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  pages          Page[]
  memoryEntries  MemoryEntry[]
  changeLog      ChangeLogEntry[]
  deployments    Deployment[]
  assets         Asset[]

  @@index([createdAt])
}

model Page {
  id         String   @id @default(cuid())
  siteId     String
  site       Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name       String
  slug       String
  pagePrompt String   @default("")
  locked     Boolean  @default(false)
  orderIdx   Int      @default(0)
  navVisible Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sections   Section[]

  @@unique([siteId, slug])
  @@index([siteId, orderIdx])
}

model Section {
  id                 String   @id @default(cuid())
  pageId             String
  page               Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type               String   // header | hero | features | cta | footer | custom | ...
  sectionPrompt      String   @default("")
  locked             Boolean  @default(false)
  orderIdx           Int      @default(0)
  html               String   @default("")
  css                String   @default("")
  js                 String   @default("")
  referenceImageUrl  String?
  lastGeneratedAt    DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([pageId, orderIdx])
}

model MemoryEntry {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  role      String   // system | user | ai
  kind      String   // change_request | decision | generation | vision
  content   String
  createdAt DateTime @default(now())

  @@index([siteId, createdAt])
}

model ChangeLogEntry {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  scope     String   // site | page | section
  targetId  String
  actor     String   @default("user")
  summary   String
  diffJson  String   @default("{}")
  createdAt DateTime @default(now())

  @@index([siteId, createdAt])
}

model Deployment {
  id              String   @id @default(cuid())
  siteId          String
  site            Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  coolifyAppUuid  String?
  deploymentUuid  String?
  url             String?
  status          String   @default("pending")
  logs            String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([siteId, createdAt])
}

model Asset {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  kind      String   // image | font
  url       String
  mime      String
  sizeBytes Int
  createdAt DateTime @default(now())

  @@index([siteId])
}
