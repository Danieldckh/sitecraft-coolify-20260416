generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Site {
  id             String   @id @default(cuid())
  name           String
  sitePrompt     String   @default("")
  planJson       String   @default("")
  stylePresetId  String?
  domain         String?
  locked         Boolean  @default(false)
  memorySummary  String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  pages          Page[]
  theme          Theme?
  assets         Asset[]
  conversations  Conversation[]
  memoryEntries  MemoryEntry[]
  changeLog      ChangeLogEntry[]
  deployments    Deployment[]

  @@index([createdAt])
}

model Theme {
  id               String   @id @default(cuid())
  siteId           String   @unique
  site             Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  stylePresetId    String
  tokensJson       String   @default("{}")
  signatureMotif   String   @default("")
  libraryJson      String   @default("{}") // { Header:{html,css}, Footer:{html,css}, Button:{html,css}, Card:{html,css} }
  primaryFont      String   @default("")
  secondaryFont   String    @default("")
  paletteJson      String   @default("{}") // { primary, secondary, accent, surface, ink, muted }
  lastGeneratedAt  DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Page {
  id              String   @id @default(cuid())
  siteId          String
  site            Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name            String
  slug            String
  pagePrompt      String   @default("")
  pageHtml        String   @default("")
  pageCss         String   @default("")
  pageJs          String   @default("")
  orderIdx        Int      @default(0)
  navVisible      Boolean  @default(true)
  locked          Boolean  @default(false)
  lastGeneratedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  elements        Element[]

  @@unique([siteId, slug])
  @@index([siteId, orderIdx])
}

model Element {
  id            String   @id @default(cuid())
  pageId        String
  page          Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  selectorId    String   // "sc-el-<cuid>"
  role          String   // hero|features|cta|testimonials|gallery|pricing|faq|contact|about-story|services-grid|footer-big|header-nav|custom
  variantId     String   @default("")
  prompt        String   @default("")
  html          String   @default("")
  css           String   @default("")
  orderIdx      Int      @default(0)
  locked        Boolean  @default(false)
  lastEditedAt  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([pageId, selectorId])
  @@index([pageId, orderIdx])
}

model Asset {
  id         String   @id @default(cuid())
  siteId     String
  site       Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  kind       String   // logo | image | favicon | font
  url        String
  mime       String
  sizeBytes  Int
  meta       String   @default("{}")
  createdAt  DateTime @default(now())

  @@index([siteId])
}

model Conversation {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  scope     String   // site | page | element
  targetId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions Question[]

  @@index([siteId])
}

model Question {
  id               String   @id @default(cuid())
  conversationId   String
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  kind             String   // text | choice | upload | boolean
  question         String
  choicesJson      String?
  response         String?
  responseAssetId  String?
  orderIdx         Int      @default(0)
  createdAt        DateTime @default(now())

  @@index([conversationId, orderIdx])
}

model MemoryEntry {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  role      String   // system | user | ai
  kind      String   // change_request | decision | generation | vision | theme | page | element
  content   String
  createdAt DateTime @default(now())

  @@index([siteId, createdAt])
}

model ChangeLogEntry {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  scope     String   // site | theme | page | element
  targetId  String
  actor     String   @default("user")
  summary   String
  diffJson  String   @default("{}")
  createdAt DateTime @default(now())

  @@index([siteId, createdAt])
}

model Deployment {
  id              String   @id @default(cuid())
  siteId          String
  site            Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  coolifyAppUuid  String?
  deploymentUuid  String?
  url             String?
  status          String   @default("pending")
  logs            String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([siteId, createdAt])
}
